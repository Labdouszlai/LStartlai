<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationDefaultFont>Segoe UI; 10</ApplicationDefaultFont>
    <ApplicationIcon>assets\icon.ico</ApplicationIcon>
    <AssemblyName>LStartlai</AssemblyName>
    <RootNamespace>LStartlai</RootNamespace>
    <Nullable>enable</Nullable>
    <Version>1.0.0.0</Version>
    <Company>L'Abdouszlai</Company>
    <Product>LStartlai</Product>
    <Description>Startup Manager — manage programs that run when Windows starts</Description>
    <Copyright>Copyright © L'Abdouszlai 2026</Copyright>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="tools\**" />
  </ItemGroup>
</Project>
